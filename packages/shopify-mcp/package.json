{
  "name": "@cmsmcp/shopify",
  "version": "0.3.2",
  "description": "MCP server for Shopify — full Admin REST API coverage with 150+ tools for products, orders, customers, inventory, content, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cmsmcp-shopify": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cmsmcp/shared": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "mcp",
    "shopify",
    "shopify-api",
    "shopify-admin",
    "ecommerce",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "mcp-server",
    "online-store",
    "products",
    "orders",
    "inventory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rahhuul/cms-mcp-hub",
    "directory": "packages/shopify-mcp"
  },
  "homepage": "https://github.com/rahhuul/cms-mcp-hub",
  "author": "Rahul Patel <rahul.patel786@gmail.com>",
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
