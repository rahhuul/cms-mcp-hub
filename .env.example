# ─── WordPress ────────────────────────────────────────
WORDPRESS_URL=https://yoursite.com
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── WooCommerce ──────────────────────────────────────
WOOCOMMERCE_URL=https://yourstore.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxx

# ─── Shopify ──────────────────────────────────────────
SHOPIFY_STORE=mystore
SHOPIFY_ACCESS_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2025-01

# ─── Framer ───────────────────────────────────────────
FRAMER_PROJECT_URL=https://framer.com/projects/your-project-id
FRAMER_API_KEY=framer_xxx

# ─── Strapi ───────────────────────────────────────────
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=xxx

# ─── Ghost ────────────────────────────────────────────
GHOST_URL=https://myblog.com
GHOST_ADMIN_API_KEY=id:secret
GHOST_CONTENT_API_KEY=xxx

# ─── Webflow ──────────────────────────────────────────
WEBFLOW_API_TOKEN=xxx

# ─── Payload CMS ──────────────────────────────────────
PAYLOAD_URL=http://localhost:3000
PAYLOAD_API_KEY=xxx
# Or use email/password auth:
# PAYLOAD_EMAIL=admin@example.com
# PAYLOAD_PASSWORD=xxx

# ─── Contentful ───────────────────────────────────────
CONTENTFUL_SPACE_ID=xxx
CONTENTFUL_MANAGEMENT_TOKEN=xxx
CONTENTFUL_ENVIRONMENT=master

# ─── Wix ──────────────────────────────────────────────
WIX_API_KEY=xxx
WIX_SITE_ID=xxx

# ─── Yoast SEO ────────────────────────────────────────
YOAST_SITE_URL=https://mysite.com
YOAST_USERNAME=admin
YOAST_APP_PASSWORD=xxx

# ─── Sanity ───────────────────────────────────────────
SANITY_PROJECT_ID=xxx
SANITY_DATASET=production
SANITY_TOKEN=xxx
SANITY_API_VERSION=2024-01

# ─── Gateway ──────────────────────────────────────────
GATEWAY_PORT=4777
GATEWAY_API_KEY=your-secure-api-key
